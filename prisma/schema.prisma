generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// USER
enum Role {
  admin
  user
}

enum Gender {
  male
  female
  other
}



model User {
  id            String     @id @default(uuid())
  name          String?
  username      String?    @unique
  email         String     @unique
  emailVerified DateTime?
  password      String
  image         String?
  gender        Gender?
  dateOfBirth   DateTime?
  description   String?
  city          String?
  country       String?
  role          Role       @default(user)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActive    DateTime?  // new field to store the last active date

  // Photos
  photos        Photo[]

  // Likes
  sourceLikes   Like[]   @relation("sourceLikes")
  targetLikes   Like[]   @relation("targetLikes")
}


model Photo {
  id            String     @id @default(uuid()) 
  url           String
  publicId      String?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
}


model Like { 
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  sourceUserId  String
  sourceMember  User @relation("sourceLikes", fields: [sourceUserId], references: [id], onDelete: Cascade)

  targetUserId  String
  targetMember  User @relation("targetLikes", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([sourceUserId, targetUserId])
}