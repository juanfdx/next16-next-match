generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// USER
enum Role {
  admin
  user
}


model User {
  id            String     @id @default(uuid())
  firstName     String?
  lastName      String?
  username      String?
  email         String     @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          Role       @default(user)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}